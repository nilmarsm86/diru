{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}
{% from 'macros/titles.html.twig' import h1 %}

{% block title %}Obras{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('Obras', 'streamline-pixel:construction-building-real-eastate') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'Obras', href: path('app_building_project', {'project': project})},
            {label: 'Desglose'},
        ]) }}
    </div>

    <h2 class="mb-4">Desglose de presupuesto</h2>

    <div class="row">
        <div class="col-4">
            {% component 'Card:Card' with {
                title: 'Presupuesto estimado',
            } %}
                {% block body %}
                    <h6 class="card-subtitle mb-2">Presupuesto ajustado:</h6>
                    <h1>$ {{ money(building.getEstimatedAdjustValue()) }}</h1>
                    <h6 class="card-subtitle mb-2">ITE (resultante):</h6>
                    <h1>{{ building.getResultIte()|number_format(2) }} $/m<sup>2</sup></h1>
                    <h6 class="card-subtitle mb-2">Coeficiente de ajuste:</h6>
                    <h1>{{ building.getCoefficient() }}</h1>
                {% endblock %}
            {% endcomponent %}
        </div>

        <div class="col-8">
            {% component 'Card:Card' with {
                title: 'Anexo',
            } %}
                {% block body %}
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <strong>Constructor</strong>
                            <span class="badge text-bg-primary rounded-pill">...</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <strong>Obra</strong>
                            <span class="badge text-bg-primary rounded-pill">...</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <strong>Objetos de obra</strong>
                            <span class="badge text-bg-primary rounded-pill">...</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <strong>Cliente</strong>
                            <span class="badge text-bg-primary rounded-pill">...</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <strong>Actividad</strong>
                            <span class="badge text-bg-primary rounded-pill">...</span>
                        </li>
                    </ul>
                {% endblock %}
            {% endcomponent %}
        </div>
    </div>

    <div class="row">
        {% component 'Table:Table' %}

            {% block tableHead %}
                <tr>
                    <th>%</th>
                    <th>Número</th>
                    <th>Nombre</th>
                    <th>Importe</th>
                    <th></th>
                </tr>
            {% endblock %}

            {% block tableBody %}
                {% from 'macros/buttons.html.twig' import tableActionButton, deleteFormButton, deleteFormButton2, tableActionButton2, tableActionButton3 %}

                {% for buildingSeparateConcept in building.getBuildingSeparateConcepts() %}
                    <tr>
                        <td style="width: 120px">
                            <span>
                                <input type="number" step="0.01" placeholder="0.00" min="0" max="100"
                                   id="{{ buildingSeparateConcept.id }}" name="building[coefficient]"
                                   data-estimate-presupposition-target="field" inputmode="decimal" class="form-control"
                                   value="{{ buildingSeparateConcept.percent|number_format(2) }}" style="display: inline;width: 80px"
                                > %
                            </span>
                        </td>
                        <td>{{ buildingSeparateConcept.separateConcept.number }}</td>
                        <td>{{ buildingSeparateConcept.separateConcept.name }}</td>
                        <td>$0.00</td>
                        <td class="text-end">
                            {{ tableActionButton3('', 'fa:edit', '', 'Editar obra', '', 'btn-link') }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">No se encontraron desgloses.</td>
                    </tr>
                {% endfor %}
            {% endblock %}

        {% endcomponent %}
    </div>
{% endblock %}
