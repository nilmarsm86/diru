{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}
{% from 'macros/titles.html.twig' import h1 %}

{% block title %}País: {{ country.name }}{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('Paises', 'icon-park-outline:international') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'Paises', href: path('app_country_index')},
            {label: 'Detalle'},
        ]) }}
    </div>

    <h2 class="mb-4">País: {{ country.name }}</h2>

    {{ include('country/_detail.html.twig', {'showButton': true, 'title': title}) }}
{% endblock %}
