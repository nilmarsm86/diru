{% if app.request.query.get('modal') %}
    {{ component('IteSourceForm', {modal:app.request.query.get('modal'), iteS: ite_source, ajax: ajax}) }}
{% else %}

    {% component 'Card:Card' with {
        cssClass: 'mb-4',
        extra: '',
        headerCssClass: 'd-flex justify-content-between align-items-center',
        title: title
    } %}

        {% block header %}
            {{ include('partials/_card_header_options.html.twig', {
                goTo: 'app_ite_source_new',
                label: 'Nueva',
                title: 'Nueva fuente de información',
                entity: ite_source,
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false
            }) }}
        {% endblock %}

        {% block body %}
            {{ component('IteSourceForm', {modal:null, iteS: ite_source, ajax: ajax}) }}
        {% endblock %}

        {% block footer %}
            {{ include('partials/_card_footer.html.twig', {
                list: {href: 'app_ite_source_index', label: 'Listado', title:'Volver al listado'},
                delete: {href: 'app_ite_source_delete', label: 'Eliminar', title:'Eliminar fuente de información'},
                id: ite_source.id,
                message: 'Está seguro que desea eliminar la fuente de información?',
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false,
                entity: ite_source
            }) }}
        {% endblock %}

    {% endcomponent %}
{% endif %}
