{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}
{% from 'macros/titles.html.twig' import h1 %}

{% block title %}Desglose de presupuesto{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('Obras', 'streamline-pixel:construction-building-real-eastate') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'Obras', href: path('app_building_project', {'project': project})},
            {label: 'Desglose'},
        ]) }}
    </div>

    <h2 class="mb-4">Desglose de presupuesto</h2>

    {{ include('building_report/presupposition_estimate.html.twig', {'building': building}) }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript">

    const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]')
    const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl))
    </script>
{% endblock %}
