{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}
{% from 'macros/titles.html.twig' import h1 %}

{% block title %}Moneda: {{ currency.name }}{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('Monedas', 'streamline-ultimate:begging-hand-coin-2-bold') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'Monedas', href: path('app_currency_index')},
            {label: 'Detalle'},
        ]) }}
    </div>

    <h2 class="mb-4">Moneda: {{ currency.name }}</h2>

    {{ include('currency/_detail.html.twig', {'showButton': true, 'title': title}) }}
{% endblock %}
