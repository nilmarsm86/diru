{% component 'Card:Card' with {
    cssClass: 'mb-4',
    extra: 'id="constructive_action_detail_' ~ constructive_action.id,
    headerCssClass: 'd-flex justify-content-between align-items-center',
    title: title,
} %}

    {% block header %}
        {{ include('partials/_card_header_options.html.twig', {
            goTo: 'app_constructive_action_new',
            label: 'Nueva',
            title: 'Nueva acción constructiva',
            entity: constructive_action,
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

    {% block body %}
        <div class="table-responsive table mt-2" role="grid" aria-describedby="dataTable_info">
            <table class="table table-hover">
                <tbody>
                <tr>
                    <th>Nombre:</th>
                    <td>{{ constructive_action.name }}</td>
                </tr>
                <tr>
                    <th>Tipo:</th>
                    <td>{{ constructive_action.type }}</td>
                </tr>
                </tbody>
            </table>
        </div>
    {% endblock %}

    {% block footer %}
        {{ include('partials/_card_footer.html.twig', {
            list: {href: 'app_constructive_action_index', label: 'Listado', title:'Volver al listado'},
            edit: {href: 'app_constructive_action_edit', label: 'Editar', title:'Editar acción constructiva'},
            delete: {href: 'app_constructive_action_delete', label: 'Eliminar', title:'Eliminar acción constructiva'},
            id: constructive_action.id,
            message: 'Está seguro que desea eliminar la acción constructiva?',
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

{% endcomponent %}


