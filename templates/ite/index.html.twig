{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}
{% from 'macros/titles.html.twig' import h1 %}

{% block title %}ITE{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('ITE') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'ITE'},
        ]) }}
    </div>

    <h2 class="mb-4">Gestión de ITE {% if type is defined %}{{ type.getLabelFrom(type) }}{% endif %}</h2>

    {% component ManagePage %}
        {% block list %}
            {{ include('ite/_list.html.twig') }}
        {% endblock %}
    {% endcomponent %}
{% endblock %}
