{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}
{% from 'macros/titles.html.twig' import h1 %}

{% block title %}Monedas{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('Monedas', 'streamline-ultimate:begging-hand-coin-2-bold') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'Monedas'},
        ]) }}
    </div>

    <h2 class="mb-4">Gestión de monedas</h2>

    {% component ManagePage %}
        {% block list %}
            {{ include('currency/_list.html.twig') }}
        {% endblock %}
    {% endcomponent %}
{% endblock %}
