{% extends 'content.html.twig' %}

{% from 'macros/titles.html.twig' import h1 %}

{% block title %}Backup{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('Backup', 'iconoir:database-backup') }}
    </div>

    <div class="row">
        <div class="col">
            {% component 'Card:Card' with {
                cssClass: 'text-bg-light mb-3'
            } %}
                {% block body %}
                    <h6 class="card-subtitle mb-2">Exportar</h6>
                    <p>Realiza una salva del sistema.</p>
                    <form action="{{ path('database_backup_export') }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('export-db') }}">
                        <button type="submit" class="btn btn-primary">
                            {{ ux_icon('bi:download', {class:'bi'}) }}
                            Realizar salva
                        </button>
                    </form>
                {% endblock %}
            {% endcomponent %}
        </div>

        <div class="col">
            {% component 'Card:Card' with {
                title: 'Proyectos',
            } %}
                {% block body %}
                    <h6 class="card-subtitle mb-2">Importar</h6>
                    <p class="text-danger">
                        <strong>Advertencia:</strong> se reemplazará la base de datos actual.
                        Se guardará un backup automático junto al archivo original (<code>.backup</code>).
                    </p>
                    {{ form_start(import_form, { attr: { enctype: 'multipart/form-data' }, action: path('database_backup_import') }) }}
                    {{ form_row(import_form.database) }}
{#                    {{ form_row(import_form.submit) }}#}
                    {{ component('button:submit', {
                        icon: 'bi:upload',
                        label: 'Importar y reemplazar',
                        type: 'primary',
                        size: null,
                        component: null
                    }) }}
                    {{ form_end(import_form) }}
                {% endblock %}
            {% endcomponent %}
        </div>
    </div>
{% endblock %}
