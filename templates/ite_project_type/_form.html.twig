{% if app.request.query.get('modal') %}
    {{ component('IteProjectTypeForm', {modal:app.request.query.get('modal'), itePT: ite_project_type, ajax: ajax}) }}
{% else %}

    {% component 'Card:Card' with {
        cssClass: 'mb-4',
        extra: '',
        headerCssClass: 'd-flex justify-content-between align-items-center',
        title: title
    } %}

        {% block header %}
            {{ include('partials/_card_header_options.html.twig', {
                goTo: 'app_ite_project_type_new',
                label: 'Nuevo',
                title: 'Nuevo tipo de proyecto',
                entity: ite_project_type,
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false
            }) }}
        {% endblock %}

        {% block body %}
            {{ component('IteProjectTypeForm', {modal:null, itePT: ite_project_type, ajax: ajax}) }}
        {% endblock %}

        {% block footer %}
            {{ include('partials/_card_footer.html.twig', {
                list: {href: 'app_ite_project_type_index', label: 'Listado', title:'Volver al listado'},
                delete: {href: 'app_ite_project_type_delete', label: 'Eliminar', title:'Eliminar tipo de proyecto de ITE'},
                id: ite_project_type.id,
                message: 'Está seguro que desea eliminar el tipo de proyecto de ITE?',
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false,
                entity: ite_project_type
            }) }}
        {% endblock %}

    {% endcomponent %}
{% endif %}
