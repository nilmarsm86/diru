{% component 'Table:Table' with {
    paginator: paginator,
    amount: app.request.query.get('modal') ? false : true,
    filter: app.request.query.get('modal') ? false : true,
    showPage: app.request.query.get('modal') ? false : true,
    navigation: app.request.query.get('modal') ? false : true,
} %}

    {% block tableHead %}
        <tr>
            <th>Concepto</th>
            <th>Cantidad</th>
            <th>Unidad de medida</th>
            <th>Precio</th>
            <th>Importe</th>
            <th></th>
        </tr>
    {% endblock %}

    {% block tableBody %}
        {% from 'macros/buttons.html.twig' import tableActionButton, deleteFormButton, deleteFormButton2, tableActionButton2, tableActionButton3 %}

        {% for just_value_estimate in paginator.getData() %}
            <tr {# stimulusController('delete-form-container') #}>
                <td>{{ just_value_estimate.concept }}</td>
                <td>{{ just_value_estimate.quantity }}</td>
                <td>{{ just_value_estimate.measurementUnit }}</td>
                <td>{{ just_value_estimate.getFormatedPrice() }}</td>
                <td>{{ just_value_estimate.getFormatedTotalPrice() }}</td>
                <td class="text-end">
                    {% set action_show = stimulusController('modal-content-loader', {
                        url: path('app_just_value_estimate_show', {'id': just_value_estimate.id, 'modal':'modal-load', 'state':'modal', 'building' : building}),
                        id: 'modal-load',
                        placeholder: 'Cargando...',
                        title: 'Detalle de la urbanización',
                    }) ~ stimulusTarget('modal-content-loader', 'button') %}
                    {{ tableActionButton3(path('app_just_value_estimate_show', {'id': just_value_estimate.id, 'building' : building}), 'bi:eye', '', 'Detalle de la preparación técnica', action_show, 'btn-link') }}
{#                    {% if not app.request.query.get('modal') %}#}
{#                        #}{#                            {{ tableActionButton3(path('app_organism_show', {'id': organism.id}), 'bi:eye', '', 'Detalle del organismo', stimulusAction('twig/table/table', 'selectElement:prevent', null, {url:path('app_organism_show', {'id': organism.id})})) }} #}
{#                        {{ tableActionButton3(path('app_urbanization_estimate_edit', {'id': urbanization_estimate.id}), 'fa:edit', '', 'Editar estimado de urbanización', stimulusAction('twig/table/table', 'selectElement:prevent', null, {url:path('app_urbanization_estimate_edit', {'id': urbanization_estimate.id})}), 'btn-link') }}#}
{#                    {% endif %}#}
                    {% set action = stimulusController('modal-content-loader', {
                        url: path('app_just_value_estimate_edit', {'building': building, 'id': just_value_estimate.id, 'modal':'modal-load', 'state':'modal'}),
                        id: 'modal-load',
                        placeholder: 'Cargando...',
                        title: 'Editar la urbanización',
                    }) ~ stimulusTarget('modal-content-loader', 'button') %}
                    {{ tableActionButton3(path('app_just_value_estimate_edit', {'id': just_value_estimate.id, 'building': building}), 'fa:edit', '', 'Editar la urbanización', action, 'btn-link') }}

                    {{ component('DeleteForm', {
                        path: path('app_just_value_estimate_delete', {'id': just_value_estimate.id, 'building': building}),
                        confirm: 'Está seguro que desea eliminar el valor estimado ajustado?',
                        token: 'delete' ~ just_value_estimate.id,
                        title: 'Eliminar estimado de urbanización',
                        icon: 'bi:trash',
                        cssClass: 'btn-link text-danger'
                    }) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">No se encontraron estimados de urbanización.</td>
            </tr>
        {% endfor %}
    {% endblock %}

{% endcomponent %}
