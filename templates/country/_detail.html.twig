{% component 'Card:Card' with {
    cssClass: 'mb-4',
    extra: 'id="country_detail_' ~ country.id,
    headerCssClass: 'd-flex justify-content-between align-items-center',
    title: title,
} %}

    {% block header %}
        {{ include('partials/_card_header_options.html.twig', {
            goTo: 'app_country_new',
            label: 'Nuevo',
            title: 'Nuevo país',
            entity: country,
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

    {% block body %}
        <div class="table-responsive table mt-2" role="grid" aria-describedby="dataTable_info">
            <table class="table table-hover">
                <tbody>
                <tr>
                    <th>Nombre:</th>
                    <td>{{ country.name }}</td>
                </tr>
                <tr>
                    <th>Ciudades:</th>
                    <td>
                        <ul class="px-0 list-unstyled">
                            {% for city in country.cities %}
                                <li>
                                    <a href="{{ path('app_city_show', {'id': city.id}) }}" target="_blank">
                                        {{ city.name }} {{ ux_icon('bx:link-external', {class:'bi'}) }}
                                    </a>
                                </li>
                            {% else %}
                                <li class="text-danger">No tiene ciudades asociadas</li>
                            {% endfor %}
                        </ul>
                    </td>
                </tr>
                </tbody>
            </table>
        </div>
    {% endblock %}

    {% block footer %}
        {{ include('partials/_card_footer.html.twig', {
            list: {href: 'app_country_index', label: 'Listado', title:'Volver al listado'},
            edit: {href: 'app_country_edit', label: 'Editar', title:'Editar país'},
            delete: {href: 'app_country_delete', label: 'Eliminar', title:'Eliminar país'},
            id: country.id,
            message: 'Está seguro que desea eliminar el país?',
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

{% endcomponent %}

