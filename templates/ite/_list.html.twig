{% component 'Card:Card' with {
    cssClass: 'mb-4',
    extra: '',
    headerCssClass: 'd-flex justify-content-between align-items-center',
    title: 'Listado de ITE '~ type.getLabelFrom(type),
} %}
    {% block header %}
        {% from 'macros/buttons.html.twig' import tableActionButton2,tableActionButton3 %}

        <div>
            {{ component('Card:Refresh', {
                path: path(path),
                queryNames:['quality', 'amount', 'filter', 'page', 'mu']
            }) }}

            {{ component('Card:FilterDropDown', {
                path:path,
                label:'Calidad',
                queryName: 'quality',
                options:qualities
            }) }}

            {{ component('Card:FilterDropDown', {
                path:path,
                label:'Unidad de medida',
                queryName: 'mu',
                options:measurementUnits
            }) }}

            {{ tableActionButton3(path('app_ite_new'), 'bi:plus-lg', 'Nuevo', 'Nuevo ITE', stimulusAction('twig/card/card', 'newElement:prevent', null, {url:path('app_ite_new')})) }}
        </div>
    {% endblock %}

    {% block body %}
        {% component 'Table:Table' with {
            paginator: paginator,
        } %}

            {% block tableHead %}
                <tr>
                    {% if type is not defined %}
                        <th>Tipo</th>
                    {% endif %}
                    {% if app.request.query.get('quality') == '' %}
                        <th>Calidad</th>
                    {% endif %}
                    <th>Min</th>
                    <th>Max</th>
                    {% if app.request.query.get('mu') == '' %}
                        <th>Unidad de Medida</th>
                    {% endif %}
                    <th>Fuente</th>
                    <th>Año de referencia</th>
                    <th>Ciudad</th>
{#                    <th>País</th>#}
                    <th>Tipo de proyecto</th>
                    <th></th>
                </tr>
            {% endblock %}

            {% block tableBody %}
                {% from 'macros/buttons.html.twig' import tableActionButton, deleteFormButton, deleteFormButton2, tableActionButton2, tableActionButton3 %}

                {% for ite in paginator.getData() %}
                    <tr {{ stimulusController('delete-form-container') }}>
                        {% if type is not defined %}
                            <td>{{ ite.type.getLabelFrom(ite.type) }}</td>
                        {% endif %}
                        {% if app.request.query.get('quality') == '' %}
                            <td>{{ ite.quality.getLabelFrom(ite.quality) }}</td>
                        {% endif %}
                        <td>{{ ite.min }}</td>
                        <td>{{ ite.max }}</td>
                        {% if app.request.query.get('mu') == '' %}
                            <td>{{ ite.measurementUnit.code }}</td>
                        {% endif %}
                        <td>{{ ite.source.name }}</td>
                        <td>{{ ite.yearReference }}</td>
                        <td>{{ ite.city.name }}</td>
{#                        <td>{{ ite.city.country.name }}</td>#}
                        <td>{{ ite.projectType.name }}</td>
                        <td class="text-end">
                            {{ tableActionButton3(path('app_ite_show', {'id': ite.id}), 'bi:eye', '', 'Detalle del ITE', stimulusAction('twig/table/table', 'selectElement:prevent', null, {url:path('app_ite_show', {'id': ite.id})}), 'btn-link') }}
                            {{ tableActionButton3(path('app_ite_edit', {'id': ite.id}), 'fa:edit', '', 'Editar ITE', stimulusAction('twig/table/table', 'selectElement:prevent', null, {url:path('app_ite_edit', {'id': ite.id})}), 'btn-link') }}

                            {{ component('DeleteForm', {
                                path: path('app_ite_delete', {'id': ite.id}),
                                confirm: 'Está seguro que desea eliminar el ITE?',
                                token: 'delete' ~ ite.id,
                                title: 'Eliminar ITE',
                                icon: 'bi:trash',
                                cssClass: 'btn-link text-danger'
                            }) }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="2">No se encontraron ITE de referencia.</td>
                    </tr>
                {% endfor %}
            {% endblock %}

        {% endcomponent %}

    {% endblock %}

{% endcomponent %}
