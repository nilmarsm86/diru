{% if app.request.query.get('modal') %}
{#    {{ component('ProvinceForm', {modal:app.request.query.get('modal'), prov: province, ajax: ajax}) }}#}
{% else %}

    {% component 'Card:Card' with {
        cssClass: 'mb-4',
        extra: '',
        headerCssClass: 'd-flex justify-content-between align-items-center',
        title: title
    } %}

        {% block header %}
            {{ include('partials/_card_header_options.html.twig', {
                goTo: 'app_ite_new',
                label: 'Nuevo',
                title: 'Nuevo ITE',
                entity: ite,
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false
            }) }}
        {% endblock %}

        {% block body %}
{#            {{ component('ProvinceForm', {modal:null, prov: province, ajax: ajax}) }}#}
        {% endblock %}

        {% block footer %}
            {{ include('partials/_card_footer.html.twig', {
                list: {href: 'app_ite_index', label: 'Listado', title:'Volver al listado'},
                delete: {href: 'app_ite_delete', label: 'Eliminar', title:'Eliminar ITE'},
                id: ite.id,
                message: 'Está seguro que desea eliminar el ITE?',
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false,
                entity: ite
            }) }}
        {% endblock %}

    {% endcomponent %}
{% endif %}
