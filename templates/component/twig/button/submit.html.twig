{% if name is not defined %}
    {% set name = 'enviar' %}
{% endif %}

{% if type is not defined %}
    {% set type = 'success' %}
{% endif %}

{% if size is not defined %}
    {% set size = 'sm' %}
{% endif %}
<button
    type="submit"
    class="btn btn-{{ type }} {% if size is not null %}btn-{{ size }}{% endif %}
        {% if component %}
            {# component.hasValidationErrors ? 'disabled' : '' #}
        {% endif %}"
    name="enviar"
>
    {{ ux_icon(icon, {class:'bi'}) }}
    {{ label }}
</button>
