{% component 'Card:Card' with {
    cssClass: 'mb-4',
    extra: 'id="currency_detail_' ~ currency.id,
    headerCssClass: 'd-flex justify-content-between align-items-center',
    title: title,
} %}

    {% block header %}
        {{ include('partials/_card_header_options.html.twig', {
            goTo: 'app_currency_new',
            label: 'Nueva',
            title: 'Nueva moneda',
            entity: currency,
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

    {% block body %}
        <div class="table-responsive table mt-2" role="grid" aria-describedby="dataTable_info">
            <table class="table table-hover">
                <tbody>
                <tr>
                    <th>Nombre:</th>
                    <td>{{ currency.name }}</td>
                </tr>
                <tr>
                    <th>Código:</th>
                    <td>{{ currency.code }}</td>
                </tr>
                </tbody>
            </table>
        </div>
    {% endblock %}

    {% block footer %}
        {{ include('partials/_card_footer.html.twig', {
            list: {href: 'app_currency_index', label: 'Listado', title:'Volver al listado'},
            edit: {href: 'app_currency_edit', label: 'Editar', title:'Editar moneda'},
            delete: {href: 'app_currency_delete', label: 'Eliminar', title:'Eliminar moneda'},
            id: currency.id,
            message: 'Está seguro que desea eliminar la moneda?',
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

{% endcomponent %}

