{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^3.10.5",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6.5",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpoffice/phpspreadsheet": "^5.7",
        "phpstan/phpdoc-parser": "^2.3.2",
        "sensiolabs/minify-bundle": ">=1.2",
        "symfony/asset": "7.4.*",
        "symfony/asset-mapper": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/expression-language": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/html-sanitizer": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/rate-limiter": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/security-csrf": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/stimulus-bundle": "^2.35",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/ux-icons": "^2.35",
        "symfony/ux-live-component": "^2.35",
        "symfony/ux-twig-component": "^2.35",
        "symfony/validator": "7.4.*",
        "symfony/web-link": "7.4.*",
        "symfony/yaml": "7.4.*",
        "symfonycasts/dynamic-forms": "^0.2.0",
        "twig/extra-bundle": "^2.12|^3.24",
        "twig/string-extra": "^3.24",
        "twig/twig": "^2.12|^3.24"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "phpstan": "phpstan analyse",
        "php-cs-fixer": ".\\vendor\\bin\\php-cs-fixer fix src",
        "phpmd":      "php bin/phpmd-pretty",
        "phpmd:next": "php bin/phpmd-pretty",
        "phpmd:0":    "php bin/phpmd-pretty 0",
        "phpmd:1":    "php bin/phpmd-pretty 1",
        "phpmd:2":    "php bin/phpmd-pretty 2",
        "phpmd:3":    "php bin/phpmd-pretty 3",
        "phpmd:4":    "php bin/phpmd-pretty 4",
        "phpmd:5":    "php bin/phpmd-pretty 5",
        "phpmd:6":    "php bin/phpmd-pretty 6",
        "quality": ["@phpmd", "@cs-check", "@phpstan"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "require-dev": {
        "dbrekelmans/bdi": "^1.4.1",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "friendsofphp/php-cs-fixer": "^3.95.1",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.1.54",
        "phpstan/phpstan-doctrine": "^2.0.22",
        "phpstan/phpstan-strict-rules": "^2.0.11",
        "phpstan/phpstan-symfony": "^2.0.17",
        "phpunit/phpunit": "^9.6.34",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/debug-bundle": "7.4.*",
        "symfony/filesystem": "7.4.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/panther": "^2.4",
        "symfony/phpunit-bridge": "^7.4.8",
        "symfony/stopwatch": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*"
    }
}
