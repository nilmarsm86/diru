{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}

{% block title %}Acción constructiva: {{ constructive_action.name }}{% endblock %}
{% from 'macros/titles.html.twig' import h1 %}

{% block content %}
    <div class="row">
        {{ h1('Acción constructiva') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'Acciones constructivas', href: path('app_constructive_action_index')},
            {label: 'Detalle'},
        ]) }}
    </div>

    <h2 class="mb-4">Acción constructiva: {{ constructive_action.name }}</h2>

    {{ include('constructive_action/_detail.html.twig', {'showButton': true, 'title': title}) }}
{% endblock %}
