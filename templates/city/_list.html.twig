{% component 'Card:Card' with {
    cssClass: 'mb-4',
    extra: '',
    headerCssClass: 'd-flex justify-content-between align-items-center',
    title: 'Listado de ciudades',
} %}
    {% block header %}
        {% from 'macros/buttons.html.twig' import tableActionButton3 %}

        <div>
            {{ tableActionButton3(path('app_city_new'), 'bi:plus-lg', 'Nueva', 'Nueva ciudad', stimulusAction('twig/card/card', 'newElement:prevent', null, {url:path('app_city_new')})) }}
        </div>
    {% endblock %}

    {% block body %}
        {% component 'Table:Table' with {
            paginator: paginator,
        } %}

            {% block tableHead %}
                <tr>
                    <th>Nombre</th>
                    <th>País {{ ux_icon('mdi:filter', {class:'bi'}) }}</th>
                    <th></th>
                </tr>
            {% endblock %}

            {% block tableBody %}
                {% from 'macros/buttons.html.twig' import tableActionButton3 %}
                {% from 'macros/link.html.twig' import filterLink %}

                {% for city in paginator.getData() %}
                    <tr {{ stimulusController('delete-form-container') }}>
                        <td>{{ city.name }}</td>
                        <td>
                            <a href="{{ filterLink(city.country) }}"
                               class="text-decoration-none"
                            >
                                {{ city.country }}
                            </a>
                        </td>
                        <td class="text-end">
{#                            {{ tableActionButton3(path('app_municipality_show', {'id': municipality.id}), 'bi:eye', '', 'Detalle del municipio', stimulusAction('twig/table/table', 'selectElement:prevent', null, {url:path('app_municipality_show', {'id': municipality.id})})) }}#}
                            {{ tableActionButton3(path('app_city_edit', {'id': city.id}), 'fa:edit', '', 'Editar ciudad', stimulusAction('twig/table/table', 'selectElement:prevent', null, {url:path('app_city_edit', {'id': city.id})}), 'btn-link') }}

                            {{ component('DeleteForm', {
                                path: path('app_city_delete', {'id': city.id}),
                                confirm: 'Está seguro que desea eliminar la ciudad?',
                                token: 'delete' ~ city.id,
                                title: 'Eliminar ciudad',
                                icon: 'bi:trash',
                                cssClass: 'btn-link text-danger'
                            }) }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3">No se encontraron ciudades.</td>
                    </tr>
                {% endfor %}
            {% endblock %}

        {% endcomponent %}

    {% endblock %}

{% endcomponent %}
