<tbody>
    <tr>
        <td colspan="4"><strong>Nombre:</strong> {{ sub_system.name }}</td>
{#        <td colspan="2">{{ sub_system.name }}</td>#}
    </tr>

    <tr class="detail_row">
        <th style="width: 25%;">Área útil (m<sup>2</sup>):</th>
        <td>{{ sub_system.getUsefulArea()|number_format(2) }}</td>

        <th>Área muro (m<sup>2</sup>):</th>
        <td>{{ sub_system.getWallArea()|number_format(2) }}</td>
    </tr>

    <tr class="detail_row">
        <th>Área de vacío (m<sup>2</sup>):</th>
        <td>{{ sub_system.getEmptyArea()|number_format(2) }}</td>

        <th>Área total (m<sup>2</sup>):</th>
        <td>{{ sub_system.getTotalArea()|number_format(2) }}</td>
    </tr>

    <tr class="detail_row">
        <th>Altura máxima (m):</th>
        <td>{{ sub_system.getMaxHeight()|number_format(2) }}</td>

        <th>Volumen (m<sup>3</sup>):</th>
        <td>{{ sub_system.getVolume()|number_format(2) }}</td>
    </tr>
</tbody>
