{% component 'Card:Card' with {
    cssClass: 'mb-4',
    extra: 'id="measurement_unit_detail_' ~ measurement_unit.id,
    headerCssClass: 'd-flex justify-content-between align-items-center',
    title: title,
} %}

    {% block header %}
        {{ include('partials/_card_header_options.html.twig', {
            goTo: 'app_measurement_unit_new',
            label: 'Nueva',
            title: 'Nueva unidad de medida',
            entity: measurement_unit,
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

    {% block body %}
        <div class="table-responsive table mt-2" role="grid" aria-describedby="dataTable_info">
            <table class="table table-hover">
                <tbody>
                <tr>
                    <th>Nombre:</th>
                    <td>{{ measurement_unit.name }}</td>
                </tr>
                <tr>
                    <th>Código:</th>
                    <td>{{ measurement_unit.code }}</td>
                </tr>
                </tbody>
            </table>
        </div>
    {% endblock %}

    {% block footer %}
        {{ include('partials/_card_footer.html.twig', {
            list: {href: 'app_measurement_unit_index', label: 'Listado', title:'Volver al listado'},
            edit: {href: 'app_measurement_unit_edit', label: 'Editar', title:'Editar unidad de medida'},
            delete: {href: 'app_measurement_unit_delete', label: 'Eliminar', title:'Eliminar unidad de medida'},
            id: currency.id,
            message: 'Está seguro que desea eliminar la unidad de medida?',
            state: 'detail',
            showButton: (showButton is defined and showButton == true) ? true : false
        }) }}
    {% endblock %}

{% endcomponent %}

