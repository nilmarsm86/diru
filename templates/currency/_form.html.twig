{% if app.request.query.get('modal') %}
    {{ component('CurrencyForm', {modal:app.request.query.get('modal'), cur: currency, ajax: ajax}) }}
{% else %}

    {% component 'Card:Card' with {
        cssClass: 'mb-4',
        extra: '',
        headerCssClass: 'd-flex justify-content-between align-items-center',
        title: title
    } %}

        {% block header %}
            {{ include('partials/_card_header_options.html.twig', {
                goTo: 'app_currency_new',
                label: 'Nueva',
                title: 'Nueva moneda',
                entity: currency,
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false
            }) }}
        {% endblock %}

        {% block body %}
            {{ component('CurrencyForm', {modal:null, cur: currency, ajax: ajax}) }}
        {% endblock %}

        {% block footer %}
            {{ include('partials/_card_footer.html.twig', {
                list: {href: 'app_currency_index', label: 'Listado', title:'Volver al listado'},
                delete: {href: 'app_currency_delete', label: 'Eliminar', title:'Eliminar moneda'},
                id: currency.id,
                message: 'Está seguro que desea eliminar la moneda?',
                state: 'form',
                showButton: (showButton is defined and showButton == true) ? true : false,
                entity: currency
            }) }}
        {% endblock %}

    {% endcomponent %}
{% endif %}
