{% extends 'content.html.twig' %}

{% from 'macros/breadcrumb.html.twig' import breadcrumb %}
{% from 'macros/titles.html.twig' import h1 %}

{% block title %}Nueva ciudad{% endblock %}

{% block content %}
    <div class="row">
        {{ h1('Ciudades', 'icon-park:local') }}

        {{ breadcrumb([
            {label: 'Inicio', href: path('app_home')},
            {label: 'Ciudades', href: path('app_city_index')},
            {label: 'Nueva'},
        ]) }}
    </div>

    <h2 class="mb-4">Agregar ciudad</h2>

    {{ include('city/_form.html.twig', {'showButton': true, title: title}) }}
{% endblock %}
